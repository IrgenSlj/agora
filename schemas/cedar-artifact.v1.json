{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "Artifact"
    },
    "id": {
      "type": "string",
      "description": "purl of the artifact"
    },
    "attributes": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "description": "Artifact kind (mcp-server or agent-skill)"
        },
        "publisher": {
          "type": "object",
          "properties": {
            "namespace": {
              "type": "string"
            },
            "identity_verified": {
              "type": "boolean"
            }
          },
          "required": [
            "namespace",
            "identity_verified"
          ],
          "additionalProperties": false,
          "description": "Cedar Publisher entity attributes"
        },
        "provenance_verified": {
          "type": "boolean"
        },
        "attestation_tier": {
          "type": "string",
          "description": "\"sigstore\" | \"local\" | \"none\""
        },
        "revoked": {
          "type": "boolean"
        },
        "canary_triggered": {
          "type": "boolean"
        },
        "fs_read": {
          "type": "boolean"
        },
        "fs_write": {
          "type": "boolean"
        },
        "exec": {
          "type": "boolean"
        },
        "net_hosts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Set of contacted hostnames"
        },
        "divergence_max": {
          "type": "string",
          "description": "\"none\" | \"info\" | \"warn\" | \"critical\""
        }
      },
      "required": [
        "kind",
        "publisher",
        "provenance_verified",
        "attestation_tier",
        "revoked",
        "canary_triggered",
        "fs_read",
        "fs_write",
        "exec",
        "net_hosts",
        "divergence_max"
      ],
      "additionalProperties": false,
      "description": "Cedar Artifact entity attributes (AGORA_BRIEF_v2.md §7.1)"
    }
  },
  "required": [
    "type",
    "id",
    "attributes"
  ],
  "additionalProperties": false,
  "description": "Cedar Artifact entity — the resource in policy evaluation"
}
