{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "undeclared-egress",
        "undeclared-fs-write",
        "undeclared-exec",
        "undeclared-credential-use",
        "canary-exfiltration"
      ]
    },
    "detail": {
      "type": "string",
      "description": "Human-readable description of the divergence"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "critical"
      ]
    }
  },
  "required": [
    "kind",
    "detail",
    "severity"
  ],
  "additionalProperties": false,
  "description": "Computed difference between declared capabilities and observed behavior"
}
