{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "adapter": {
      "type": "string",
      "enum": [
        "official",
        "glama",
        "pulsemcp",
        "skills-github",
        "manual"
      ]
    },
    "upstream_id": {
      "type": "string",
      "description": "Identifier in the upstream registry"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the artifact in the upstream registry"
    },
    "first_seen": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "description": "ISO timestamp when this source first reported the artifact"
    }
  },
  "required": [
    "adapter",
    "upstream_id",
    "url",
    "first_seen"
  ],
  "additionalProperties": false
}
