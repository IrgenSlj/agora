{
  "name": "agora-hub",
  "version": "0.6.0",
  "description": "The system manager for your agentic stack — a local-first terminal app that manages, watches, and gates your MCP servers, skills, and instruction files.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "agora": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./opencode": "./dist/plugin/index.js",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IrgenSlj/agora.git"
  },
  "homepage": "https://github.com/IrgenSlj/agora",
  "bugs": "https://github.com/IrgenSlj/agora/issues",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "uuid": "13.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp src/catalog.json dist/catalog.json && chmod +x dist/cli.js",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/agora",
    "dev": "bun run build && cp -r dist/* ~/.config/opencode/plugins/agora/",
    "typecheck": "bun run typecheck:cli",
    "typecheck:cli": "tsc -p tsconfig.check.json",
    "test": "bun test",
    "prepublishOnly": "bun run build",
    "refresh:data": "bun scripts/refresh-data.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "package-manager",
    "stack-manager",
    "agent",
    "cli",
    "opencode",
    "claude-code",
    "cursor",
    "windsurf",
    "trust",
    "federation"
  ],
  "author": "IrgenSlj",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.6.1",
    "yargs": "18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.15.11",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/yargs": "^17.0.35",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
