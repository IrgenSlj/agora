{
  "name": "opencode-agora",
  "version": "0.4.4",
  "description": "Agora - The Developer's Terminal Marketplace & Community Hub for OpenCode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "agora": "dist/cli.js",
    "opencode-agora": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IrgenSlj/agora.git"
  },
  "homepage": "https://github.com/IrgenSlj/agora",
  "bugs": "https://github.com/IrgenSlj/agora/issues",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "uuid": "13.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/cli.js",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/agora",
    "dev": "bun run build && cp -r dist/* ~/.config/opencode/plugins/agora/",
    "hub:dev": "bun hub/server.ts",
    "typecheck": "bun run typecheck:cli && bun run typecheck:backend",
    "typecheck:cli": "tsc -p tsconfig.check.json",
    "typecheck:backend": "cd backend && bun run typecheck",
    "test": "bun test",
    "prepublishOnly": "bun run build",
    "refresh:data": "bun scripts/refresh-data.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "mcp",
    "marketplace",
    "community",
    "developer-tools"
  ],
  "author": "IrgenSlj",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.15.11",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
