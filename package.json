{
  "name": "opencode-agora",
  "version": "0.2.0",
  "description": "Agora - The Developer's Terminal Marketplace & Community Hub for OpenCode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "agora": "./dist/cli.js",
    "opencode-agora": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IrgenSlj/agora.git"
  },
  "homepage": "https://github.com/IrgenSlj/agora",
  "bugs": "https://github.com/IrgenSlj/agora/issues",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun run build && cp -r dist/* ~/.config/opencode/plugins/agora/",
    "hub:dev": "bun hub/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "mcp",
    "marketplace",
    "community",
    "developer-tools"
  ],
  "author": "IrgenSlj",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "bun-types": "^1.2.0"
  },
  "test": {
    "setup": "./test/setup.ts"
  }
}
